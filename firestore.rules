rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    match /messages/{messageId} {
      allow create: if isValidId(messageId) 
        && incoming().name is string && incoming().name.size() > 0 && incoming().name.size() < 200
        && incoming().email is string && incoming().email.size() > 0 && incoming().email.size() < 200
        && incoming().message is string && incoming().message.size() > 0 && incoming().message.size() < 5000
        && incoming().createdAt == request.time;
      
      // Admin can read messages if we had an admin concept, currently denying all reads for privacy
      allow read: if false; 
    }
  }
}
